# ==============================================================================
# BareTcl 圆周率计算测试脚本
# ==============================================================================
# pi 函数已集成在 src/tcllib.tcl 中，可通过修改 pi_digits 自定义小数点后位数。
# ==============================================================================

set pi_digits 1000

puts "正在计算圆周率 Pi 小数点后 $pi_digits 位，请稍候..."
puts "计算结果 (小数点后 $pi_digits 位):"
puts [pi $pi_digits]
